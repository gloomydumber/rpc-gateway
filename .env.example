# RPC Providers
RPC_PRIMARY_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
RPC_FALLBACK_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Server
PORT=3000
NODE_ENV=development

# Rate Limiting
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_GLOBAL_WINDOW_MS=60000
RATE_LIMIT_IP_MAX=30
RATE_LIMIT_IP_WINDOW_MS=60000
RATE_LIMIT_ADDRESS_MAX=10
RATE_LIMIT_ADDRESS_WINDOW_MS=60000

# Cache
CACHE_TTL_MS=15000

# RPC Options
RPC_TIMEOUT_MS=5000
RPC_RETRY_MAX_ATTEMPTS=2
RPC_RETRY_BASE_DELAY_MS=500
RPC_RETRY_MAX_DELAY_MS=3000

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:5173
